{
	"mcp": {
		"servers": {
			"calculator": {
				"command": "uvx",
				"args": [
					"mcp-server-calculator"
				]
			},
			"time": {
				"command": "uvx",
				"args": [
					"mcp-server-time",
					"--local-timezone",
					"Asia/Yekaterinburg"
				]
			},
			"weather": {
				"command": "/home/pavelresh/projects/wttr-mcp/run.sh"
			},
			"wikipedia": {
				"command": "uvx",
				"args": [
					"--from",
					"git+https://github.com/rudra-ravi/wikipedia-mcp.git",
					"wikipedia-mcp"
				]
			}
		}
	}
}
